---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { SITE } from "../config/site";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const latestPosts = posts.slice(0, 3);
const postCount = posts.length.toString().padStart(2, "0");

const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth();
const todayDate = now.getDate();

const monthLabel = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "long"
}).format(now);

const todayLabel = new Intl.DateTimeFormat("zh-CN", {
  month: "long",
  day: "numeric",
  weekday: "long"
}).format(now);

const weekLabels = ["一", "二", "三", "四", "五", "六", "日"];
const firstDayOfMonth = new Date(currentYear, currentMonth, 1);
const daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();
const firstWeekday = (firstDayOfMonth.getDay() + 6) % 7;
const totalSlots = Math.ceil((firstWeekday + daysInMonth) / 7) * 7;

const calendarDays = Array.from({ length: totalSlots }, (_, index) => {
  const dayNumber = index - firstWeekday + 1;
  const isCurrentMonth = dayNumber > 0 && dayNumber <= daysInMonth;

  return {
    value: isCurrentMonth ? dayNumber : null,
    isCurrentMonth,
    isToday: isCurrentMonth && dayNumber === todayDate
  };
});

const formatMonthDay = (offset: number) => {
  const date = new Date(now);
  date.setDate(now.getDate() + offset);

  return new Intl.DateTimeFormat("zh-CN", {
    month: "numeric",
    day: "numeric"
  }).format(date);
};

const agendaItems = [
  {
    time: "09:30",
    title: "整理今天的重点",
    description: "先看月历和最近发布内容，把今天最重要的 1 到 3 件事定下来。"
  },
  {
    time: "14:00",
    title: "更新一篇项目记录",
    description: "把正在推进的工作沉淀成文章，首页和博客会一起形成连续更新感。"
  },
  {
    time: "19:30",
    title: "复盘本周节奏",
    description: "回顾已完成、待继续和想调整的事情，给明天留出更清晰的入口。"
  }
];

const quickLinks = [
  {
    href: "/blog",
    label: "查看文章",
    description: "继续保留博客主线，让首页工作台和内容归档连起来。"
  },
  {
    href: "/about",
    label: "编辑介绍",
    description: "把个人信息、联系方式和站点定位放到关于页，形成完整名片。"
  },
  {
    href: SITE.github,
    label: "打开 GitHub",
    description: "如果你有项目展示、作品链接或代码仓库，首页通常会放一个快捷入口。"
  }
];

const commonFeatures = [
  {
    name: "待办清单",
    detail: "最常见，适合放 3 到 5 个今天必须处理的事项。"
  },
  {
    name: "最近安排",
    detail: "显示本周会议、发布时间、DDL 或重要提醒。"
  },
  {
    name: "习惯打卡",
    detail: "如果是个人主页，经常会加阅读、运动、写作之类的连续记录。"
  },
  {
    name: "数据概览",
    detail: "比如文章数量、项目数、访问量、连续更新天数。"
  }
];

const upcomingMoments = [
  {
    date: formatMonthDay(1),
    title: "发布一篇新内容",
    detail: "把最近做的功能、踩坑记录或周总结发出来。"
  },
  {
    date: formatMonthDay(3),
    title: "整理本周计划",
    detail: "把想做的事收拢成 3 个优先级最高的目标。"
  },
  {
    date: formatMonthDay(6),
    title: "更新作品入口",
    detail: "补一下 GitHub、项目页或个人介绍，让首页信息更完整。"
  }
];
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <section class="hero hero--dashboard">
    <div class="hero__content">
      <span class="eyebrow">Home Dashboard</span>
      <h1>把首页改成带日历的个人工作台。</h1>
      <p>
        现在首页已经不是默认博客模版，而是一个更适合个人主页、内容站点和轻量效率页的骨架。
        你可以把它继续接上真实日程、待办和项目数据。
      </p>
      <div class="hero__actions">
        <a class="button" href="#calendar">看月历模版</a>
        <a class="button button--ghost" href="/blog">继续保留博客入口</a>
      </div>

      <div class="hero-highlights" aria-label="首页模块">
        <span>月历总览</span>
        <span>今日安排</span>
        <span>快捷入口</span>
        <span>最近更新</span>
      </div>
    </div>

    <aside class="hero-card hero-card--dashboard">
      <span class="hero-card__label">Today</span>
      <div class="hero-card__header">
        <strong>{todayLabel}</strong>
        <span>{monthLabel}</span>
      </div>
      <div class="hero-card__metrics">
        <article>
          <span>已发布</span>
          <strong>{postCount}</strong>
        </article>
        <article>
          <span>本月主轴</span>
          <strong>内容 + 日程</strong>
        </article>
      </div>
      <p>
        这个版本先提供一个静态但完整的首页模版，后面很适合继续接入待办、提醒、日程同步或者项目统计。
      </p>
    </aside>
  </section>

  <section class="dashboard-grid" id="calendar">
    <article class="dashboard-card calendar-card">
      <div class="panel-heading">
        <div>
          <span class="eyebrow">Calendar</span>
          <h2>{monthLabel}</h2>
        </div>
        <p>首页最核心的模版块。现在展示的是当月视图，适合后续接会议、发布计划或提醒数据。</p>
      </div>

      <div class="calendar-weekdays" aria-hidden="true">
        {weekLabels.map((label) => (
          <span>{label}</span>
        ))}
      </div>

      <div class="calendar-grid">
        {calendarDays.map((day) => (
          <div class:list={["calendar-cell", !day.isCurrentMonth && "calendar-cell--muted", day.isToday && "calendar-cell--today"]}>
            {day.value ? <span>{day.value}</span> : <span>&nbsp;</span>}
          </div>
        ))}
      </div>
    </article>

    <article class="dashboard-card agenda-card">
      <div class="panel-heading">
        <div>
          <span class="eyebrow">Agenda</span>
          <h2>今天做什么</h2>
        </div>
        <p>如果你问“首页一般还有什么功能”，这一块通常会和日历一起出现。</p>
      </div>

      <div class="agenda-list">
        {agendaItems.map((item) => (
          <article class="agenda-item">
            <span class="agenda-item__time">{item.time}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </article>

    <article class="dashboard-card shortcuts-card">
      <div class="panel-heading">
        <div>
          <span class="eyebrow">Quick Access</span>
          <h2>常用入口</h2>
        </div>
        <p>首页常见的第二类功能，就是把最常点的页面放成清晰入口。</p>
      </div>

      <div class="shortcut-list">
        {quickLinks.map((item) => (
          <a class="shortcut-item" href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
            <strong>{item.label}</strong>
            <p>{item.description}</p>
          </a>
        ))}
      </div>
    </article>

    <article class="dashboard-card features-card">
      <div class="panel-heading">
        <div>
          <span class="eyebrow">Common Blocks</span>
          <h2>首页一般还会放</h2>
        </div>
        <p>如果你后面还想继续扩，下面这几类通常最实用，也最容易和日历搭配。</p>
      </div>

      <ul class="feature-list">
        {commonFeatures.map((item) => (
          <li>
            <strong>{item.name}</strong>
            <p>{item.detail}</p>
          </li>
        ))}
      </ul>
    </article>
  </section>

  <section class="content-section roadmap-section">
    <div class="section-heading">
      <span class="eyebrow">Upcoming</span>
      <h2>接下来可以继续补的安排</h2>
      <p>这块相当于“近期提醒”模版，很多首页会把它做成倒计时、提醒卡片，或者和真实日历联动。</p>
    </div>

    <div class="roadmap-list">
      {upcomingMoments.map((item) => (
        <article class="roadmap-item">
          <span>{item.date}</span>
          <h3>{item.title}</h3>
          <p>{item.detail}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="content-section">
    <div class="section-heading">
      <span class="eyebrow">Latest Notes</span>
      <h2>最近更新</h2>
      <p>博客列表继续保留，这样首页不只好看，也还能持续承接内容更新。</p>
    </div>

    <div class="post-grid">
      {latestPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  </section>
</BaseLayout>
