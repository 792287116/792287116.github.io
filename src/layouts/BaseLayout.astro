---
import { NAV_LINKS, SITE } from "../config/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  pageType?: "website" | "article";
}

const {
  title = SITE.title,
  description = SITE.description,
  image = `${SITE.siteUrl}/og-cover.svg`,
  pageType = "website"
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE.siteUrl).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content={pageType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content={SITE.title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
  </head>
  <body>
    <div class="page-shell">
      <div class="page-shell__glow page-shell__glow--one"></div>
      <div class="page-shell__glow page-shell__glow--two"></div>
      <header class="site-header">
        <a class="brand" href="/">
          <span class="brand__mark">SF</span>
          <span>
            <strong>{SITE.title}</strong>
            <small>{SITE.author}</small>
          </span>
        </a>
        <nav aria-label="主导航">
          <ul class="nav-list">
            {NAV_LINKS.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <p>{SITE.description}</p>
        <div class="site-footer__links">
          <a href={SITE.github} target="_blank" rel="noreferrer">GitHub</a>
          <a href={SITE.email}>Email</a>
        </div>
      </footer>
    </div>
  </body>
</html>
